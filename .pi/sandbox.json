{
  "enabled": true,
  "allowBrowserProcess": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": [
      "github.com",
      "*.github.com"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "/Users",
      "/home"
    ],
    "allowRead": [
      "~/.config",
      "~/.local",
      "."
    ],
    "allowWrite": [
      "."
    ],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key"
    ]
  }
}
